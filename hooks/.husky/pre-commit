#!/bin/sh
set -e

echo "Running pre-commit checks..."

# 1. Lint
npm run lint --silent || (echo "ESLint failed"; exit 1)

# 2. Format check
npm run format:check --silent || (echo "Prettier formatting issues"; exit 1)

# 3. Tests (only on staged files)
npm test --silent || (echo "Tests failed"; exit 1)

# 4. Secrets scan
npm run secrets:scan --silent || (echo "Secrets detected!"; exit 1)

echo "✓ All checks passed!"
